{
  "name": "abapfs-workspaces",
  "displayName": "ABAP FS Workspaces",
  "description": "Manage Remote ABAP connections as Workspaces",
  "version": "0.0.3",
  "publisher": "gsingh704",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "ABAP",
    "workspace",
    "SAP",
    "remote"
  ],
    "author": {
    "name": "Gurjant Singh",
    "email": "gurjant.dev@gmail.com",
    "url": "https://gurjant.fyi"
  },
   "repository": {
    "type": "git",
    "url": "https://github.com/gsingh704/abapFS-workspaces"
  },
  "icon": "media/icon.png",
  "main": "./src/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "license": "MIT",
  "contributes": {
    "commands": [
      {
        "command": "abapFS-workspaces.workspaceManager",
        "title": "Workspace Manager",
        "category": "ABAP FS Workspaces",
        "icon": "$(files)"
      },
      {
        "command": "abapFS-workspaces.openAbapFsConnectionManager",
        "title": "Open ABAP FS Connection Manager",
        "category": "ABAP FS Workspaces",
        "icon": "$(settings-gear)"
      },
      {
        "command": "abapFS-workspaces.refreshWorkspaceList",
        "title": "Refresh Workspace List",
        "category": "ABAP FS Workspaces",
        "icon": "$(refresh)"
      },
      {
        "command": "abapFS-workspaces.generateWorkspaceFiles",
        "title": "Generate Or Regenerate Workspaces",
        "category": "ABAP FS Workspaces",
        "icon": "$(run-all)"
      },
      {
        "command": "abapFS-workspaces.openConnectionWorkspace",
        "title": "Open Generated Workspace",
        "category": "ABAP FS Workspaces",
        "icon": "$(folder-opened)"
      },
      {
        "command": "abapFS-workspaces.openConnectionWorkspaceInNewWindow",
        "title": "Open Generated Workspace In New Window",
        "category": "ABAP FS Workspaces",
        "icon": "$(link-external)"
      },
      {
        "command": "abapFS-workspaces.editConnectionWorkspaceFile",
        "title": "Edit Generated Workspace File",
        "category": "ABAP FS Workspaces",
        "icon": "$(edit)"
      },
      {
        "command": "abapFS-workspaces.selectStoragePath",
        "title": "Choose Workspace Save Location",
        "category": "ABAP FS Workspaces",
        "icon": "$(folder-library)"
      },
      {
        "command": "abapFS-workspaces.clearStoragePath",
        "title": "Clear Workspace Save Location",
        "category": "ABAP FS Workspaces",
        "icon": "$(trash)"
      },
      {
        "command": "abapFS-workspaces.addGlobalFolder",
        "title": "Add Global Folder",
        "category": "ABAP FS Workspaces",
        "icon": "$(new-folder)"
      },
      {
        "command": "abapFS-workspaces.removeGlobalFolder",
        "title": "Remove Global Folder",
        "category": "ABAP FS Workspaces",
        "icon": "$(close)"
      },
      {
        "command": "abapFS-workspaces.addCustomWorkspace",
        "title": "Add Custom Workspace",
        "category": "ABAP FS Workspaces",
        "icon": "$(folder-library)"
      },
      {
        "command": "abapFS-workspaces.editCustomWorkspaceName",
        "title": "Edit Custom Workspace Name",
        "category": "ABAP FS Workspaces",
        "icon": "$(edit)"
      },
      {
        "command": "abapFS-workspaces.removeCustomWorkspace",
        "title": "Remove Custom Workspace",
        "category": "ABAP FS Workspaces",
        "icon": "$(trash)"
      },
      {
        "command": "abapFS-workspaces.addCustomWorkspaceConnection",
        "title": "Add Connection To Custom Workspace",
        "category": "ABAP FS Workspaces",
        "icon": "$(plug)"
      },
      {
        "command": "abapFS-workspaces.removeCustomWorkspaceConnection",
        "title": "Remove Connection From Custom Workspace",
        "category": "ABAP FS Workspaces",
        "icon": "$(close)"
      },
      {
        "command": "abapFS-workspaces.addCustomWorkspaceFolder",
        "title": "Add Folder To Custom Workspace",
        "category": "ABAP FS Workspaces",
        "icon": "$(new-folder)"
      },
      {
        "command": "abapFS-workspaces.removeCustomWorkspaceFolder",
        "title": "Remove Folder From Custom Workspace",
        "category": "ABAP FS Workspaces",
        "icon": "$(close)"
      },
      {
        "command": "abapFS-workspaces.editConnectionWorkspaceName",
        "title": "Edit Connection Workspace Name",
        "category": "ABAP FS Workspaces",
        "icon": "$(edit)"
      },
      {
        "command": "abapFS-workspaces.editConnectionColor",
        "title": "Edit Connection Color",
        "category": "ABAP FS Workspaces",
        "icon": "$(symbol-color)"
      },
      {
        "command": "abapFS-workspaces.editConnectionBadge",
        "title": "Edit Connection Icon",
        "category": "ABAP FS Workspaces",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "abapFS-workspaces.addConnectionFolder",
        "title": "Add Connection Folder",
        "category": "ABAP FS Workspaces",
        "icon": "$(new-folder)"
      },
      {
        "command": "abapFS-workspaces.removeConnectionFolder",
        "title": "Remove Connection Folder",
        "category": "ABAP FS Workspaces",
        "icon": "$(close)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "abapFsWorkspaces",
          "title": "ABAP FS Workspaces",
          "icon": "$(folder-library)"
        }
      ]
    },
    "views": {
      "abapFsWorkspaces": [
        {
          "id": "abapFsWorkspaces.workspaceManager",
          "name": "Workspace Manager",
          "icon": "$(settings-gear)"
        },
        {
          "id": "abapFsWorkspaces.workspaceList",
          "name": "Generated Workspaces",
          "icon": "$(folder-opened)"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "abapFS-workspaces.openConnectionWorkspace",
          "group": "inline@1",
          "when": "view == abapfs.connections && viewItem =~ /connection-(global|workspace)$/"
        },
        {
          "command": "abapFS-workspaces.openConnectionWorkspaceInNewWindow",
          "group": "inline@1",
          "when": "view == abapFsWorkspaces.workspaceList && viewItem == workspaceConnection"
        },
        {
          "command": "abapFS-workspaces.editConnectionWorkspaceFile",
          "group": "inline@2",
          "when": "view == abapFsWorkspaces.workspaceList && viewItem == workspaceConnection"
        },
        {
          "command": "abapFS-workspaces.selectStoragePath",
          "group": "inline@1",
          "when": "view == abapFsWorkspaces.workspaceManager && viewItem == managerStoragePath"
        },
        {
          "command": "abapFS-workspaces.clearStoragePath",
          "group": "inline@2",
          "when": "view == abapFsWorkspaces.workspaceManager && viewItem == managerStoragePath"
        },
        {
          "command": "abapFS-workspaces.addGlobalFolder",
          "group": "inline@1",
          "when": "view == abapFsWorkspaces.workspaceManager && viewItem == managerGlobalFoldersRoot"
        },
        {
          "command": "abapFS-workspaces.removeGlobalFolder",
          "group": "inline@1",
          "when": "view == abapFsWorkspaces.workspaceManager && viewItem == managerGlobalFolder"
        },
        {
          "command": "abapFS-workspaces.addCustomWorkspace",
          "group": "inline@1",
          "when": "view == abapFsWorkspaces.workspaceManager && viewItem == managerCustomWorkspacesRoot"
        },
        {
          "command": "abapFS-workspaces.editCustomWorkspaceName",
          "group": "inline@1",
          "when": "view == abapFsWorkspaces.workspaceManager && viewItem == managerCustomWorkspace"
        },
        {
          "command": "abapFS-workspaces.addCustomWorkspaceConnection",
          "group": "inline@2",
          "when": "view == abapFsWorkspaces.workspaceManager && viewItem == managerCustomWorkspace"
        },
        {
          "command": "abapFS-workspaces.addCustomWorkspaceFolder",
          "group": "inline@3",
          "when": "view == abapFsWorkspaces.workspaceManager && viewItem == managerCustomWorkspace"
        },
        {
          "command": "abapFS-workspaces.removeCustomWorkspace",
          "group": "inline@4",
          "when": "view == abapFsWorkspaces.workspaceManager && viewItem == managerCustomWorkspace"
        },
        {
          "command": "abapFS-workspaces.removeCustomWorkspaceConnection",
          "group": "inline@1",
          "when": "view == abapFsWorkspaces.workspaceManager && viewItem == managerCustomWorkspaceConnection"
        },
        {
          "command": "abapFS-workspaces.removeCustomWorkspaceFolder",
          "group": "inline@1",
          "when": "view == abapFsWorkspaces.workspaceManager && viewItem == managerCustomWorkspaceFolder"
        },
        {
          "command": "abapFS-workspaces.editConnectionWorkspaceName",
          "group": "inline@1",
          "when": "view == abapFsWorkspaces.workspaceManager && viewItem == managerConnection"
        },
        {
          "command": "abapFS-workspaces.editConnectionColor",
          "group": "inline@2",
          "when": "view == abapFsWorkspaces.workspaceManager && viewItem == managerConnection"
        },
        {
          "command": "abapFS-workspaces.editConnectionBadge",
          "group": "inline@3",
          "when": "view == abapFsWorkspaces.workspaceManager && viewItem == managerConnection"
        },
        {
          "command": "abapFS-workspaces.addConnectionFolder",
          "group": "inline@4",
          "when": "view == abapFsWorkspaces.workspaceManager && viewItem == managerConnection"
        },
        {
          "command": "abapFS-workspaces.editConnectionColor",
          "group": "inline@1",
          "when": "view == abapFsWorkspaces.workspaceManager && viewItem == managerConnectionColor"
        },
        {
          "command": "abapFS-workspaces.editConnectionBadge",
          "group": "inline@1",
          "when": "view == abapFsWorkspaces.workspaceManager && viewItem == managerConnectionBadge"
        },
        {
          "command": "abapFS-workspaces.removeConnectionFolder",
          "group": "inline@1",
          "when": "view == abapFsWorkspaces.workspaceManager && viewItem == managerConnectionFolder"
        },
        {
          "command": "abapFS-workspaces.openConnectionWorkspace",
          "group": "inline@1",
          "when": "view == abapFsWorkspaces.workspaceManager && (viewItem == managerConnection || viewItem == managerCustomWorkspace || viewItem == managerGeneratedFile)"
        },
        {
          "command": "abapFS-workspaces.openConnectionWorkspaceInNewWindow",
          "group": "inline@2",
          "when": "view == abapFsWorkspaces.workspaceManager && (viewItem == managerConnection || viewItem == managerCustomWorkspace || viewItem == managerGeneratedFile)"
        },
        {
          "command": "abapFS-workspaces.editConnectionWorkspaceFile",
          "group": "inline@3",
          "when": "view == abapFsWorkspaces.workspaceManager && (viewItem == managerConnection || viewItem == managerCustomWorkspace || viewItem == managerGeneratedFile)"
        }
      ],
      "view/title": [
        {
          "command": "abapFS-workspaces.workspaceManager",
          "group": "navigation@100",
          "when": "view == abapfs.connections"
        },
        {
          "command": "abapFS-workspaces.openAbapFsConnectionManager",
          "group": "navigation@-1",
          "when": "view == abapFsWorkspaces.workspaceList && abapFS-workspaces.hasAbapFsConnectionManager"
        },
        {
          "command": "abapFS-workspaces.generateWorkspaceFiles",
          "group": "navigation@-3",
          "when": "view == abapFsWorkspaces.workspaceManager"
        },
        {
          "command": "abapFS-workspaces.selectStoragePath",
          "group": "navigation@-2",
          "when": "view == abapFsWorkspaces.workspaceManager"
        },
        {
          "command": "abapFS-workspaces.addGlobalFolder",
          "group": "navigation@-1",
          "when": "view == abapFsWorkspaces.workspaceManager"
        },
        {
          "command": "abapFS-workspaces.addCustomWorkspace",
          "group": "navigation",
          "when": "view == abapFsWorkspaces.workspaceManager"
        },
        {
          "command": "abapFS-workspaces.generateWorkspaceFiles",
          "group": "navigation@-2",
          "when": "view == abapFsWorkspaces.workspaceList"
        },
        {
          "command": "abapFS-workspaces.openAbapFsConnectionManager",
          "group": "navigation@1",
          "when": "view == abapFsWorkspaces.workspaceManager && abapFS-workspaces.hasAbapFsConnectionManager"
        },
        {
          "command": "abapFS-workspaces.refreshWorkspaceList",
          "group": "navigation@2",
          "when": "view == abapFsWorkspaces.workspaceManager"
        },
        {
          "command": "abapFS-workspaces.refreshWorkspaceList",
          "group": "navigation",
          "when": "view == abapFsWorkspaces.workspaceList"
        },
        {
          "command": "abapFS-workspaces.workspaceManager",
          "group": "navigation@1",
          "when": "view == abapFsWorkspaces.workspaceList"
        }
      ]
    },
    "configuration": {
      "title": "ABAP Remote FS Workspaces",
      "properties": {
        "abapFsWorkspaces.manager": {
          "type": "object",
          "default": {
            "storagePath": "",
            "globalFolders": [],
            "connections": {},
            "workspaces": []
          },
          "scope": "machine",
          "description": "Workspace Manager configuration for generated ABAP workspace files. Connections are read from abapfs.remote.",
          "properties": {
            "storagePath": {
              "type": "string",
              "default": "",
              "description": "Absolute folder path where generated .code-workspace files are written."
            },
            "globalFolders": {
              "type": "array",
              "default": [],
              "items": {
                "type": "string"
              },
              "description": "Folders included in every generated workspace."
            },
            "connections": {
              "type": "object",
              "default": {},
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "workspaceName": {
                    "type": "string",
                    "default": "",
                    "description": "Workspace file name without extension. Defaults to the connection name."
                  },
                  "color": {
                    "type": "string",
                    "default": "",
                    "enum": [
                      "",
                      "charts.red",
                      "charts.green",
                      "charts.blue",
                      "charts.yellow",
                      "charts.orange",
                      "charts.purple"
                    ],
                    "description": "Native decoration color preset for this connection in Explorer and editor tabs."
                  },
                  "badge": {
                    "type": "string",
                    "default": "",
                    "enum": [
                      "",
                      "dot",
                      "circle",
                      "ring",
                      "hollow-circle",
                      "square",
                      "hollow-square",
                      "triangle",
                      "hollow-triangle",
                      "diamond",
                      "hollow-diamond",
                      "star",
                      "hollow-star",
                      "spark",
                      "plus",
                      "cross",
                      "clover",
                      "sun",
                      "cloud",
                      "flag",
                      "bolt",
                      "anchor",
                      "rocket",
                      "fire",
                      "leaf",
                      "bug",
                      "gear",
                      "lock",
                      "key",
                      "globe",
                      "lightbulb",
                      "hammer",
                      "package",
                      "pin",
                      "shield"
                    ],
                    "description": "Native decoration icon preset for this connection in Explorer and editor tabs."
                  },
                  "folders": {
                    "type": "array",
                    "default": [],
                    "items": {
                      "type": "string"
                    },
                    "description": "Folders included only in this connection workspace."
                  }
                },
                "additionalProperties": false
              }
            },
            "workspaceColors": {
              "type": "object",
              "default": {},
              "description": "Resolved per-workspace connection colors used for native ABAP FS decorations.",
              "additionalProperties": {
                "type": "string",
                "enum": [
                  "charts.red",
                  "charts.green",
                  "charts.blue",
                  "charts.yellow",
                  "charts.orange",
                  "charts.purple"
                ]
              }
            },
            "workspaceBadges": {
              "type": "object",
              "default": {},
              "description": "Resolved per-workspace connection icons used for native ABAP FS decorations.",
              "additionalProperties": {
                "type": "string",
                "enum": [
                  "dot",
                  "circle",
                  "ring",
                  "hollow-circle",
                  "square",
                  "hollow-square",
                  "triangle",
                  "hollow-triangle",
                  "diamond",
                  "hollow-diamond",
                  "star",
                  "hollow-star",
                  "spark",
                  "plus",
                  "cross",
                  "clover",
                  "sun",
                  "cloud",
                  "flag",
                  "bolt",
                  "anchor",
                  "rocket",
                  "fire",
                  "leaf",
                  "bug",
                  "gear",
                  "lock",
                  "key",
                  "globe",
                  "lightbulb",
                  "hammer",
                  "package",
                  "pin",
                  "shield"
                ]
              }
            },
            "workspaces": {
              "type": "array",
              "default": [],
              "description": "Custom generated workspaces that can include multiple ABAP FS connections and local folders.",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "default": "",
                    "description": "Stable internal identifier for the custom workspace entry."
                  },
                  "workspaceName": {
                    "type": "string",
                    "default": "",
                    "description": "Workspace file name without extension."
                  },
                  "connectionIds": {
                    "type": "array",
                    "default": [],
                    "items": {
                      "type": "string"
                    },
                    "description": "ABAP FS connection IDs to include in this generated workspace."
                  },
                  "folders": {
                    "type": "array",
                    "default": [],
                    "items": {
                      "type": "string"
                    },
                    "description": "Local folders included only in this custom generated workspace."
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "abapFsWorkspaces.workspaceColors": {
          "type": "object",
          "default": {},
          "scope": "resource",
          "description": "Per-workspace connection colors used by native Explorer and tab decorations.",
          "additionalProperties": {
            "type": "string",
            "enum": [
              "charts.red",
              "charts.green",
              "charts.blue",
              "charts.yellow",
              "charts.orange",
              "charts.purple"
            ]
          }
        },
        "abapFsWorkspaces.workspaceBadges": {
          "type": "object",
          "default": {},
          "scope": "resource",
          "description": "Per-workspace connection icons used by native Explorer and tab decorations.",
          "additionalProperties": {
            "type": "string",
            "enum": [
              "dot",
              "circle",
              "ring",
              "hollow-circle",
              "square",
              "hollow-square",
              "triangle",
              "hollow-triangle",
              "diamond",
              "hollow-diamond",
              "star",
              "hollow-star",
              "spark",
              "plus",
              "cross",
              "clover",
              "sun",
              "cloud",
              "flag",
              "bolt",
              "anchor",
              "rocket",
              "fire",
              "leaf",
              "bug",
              "gear",
              "lock",
              "key",
              "globe",
              "lightbulb",
              "hammer",
              "package",
              "pin",
              "shield"
            ]
          }
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.41"
  }
}
